{
// HYPRLAND WORKSPACES. CHOOSE as desired and place on waybar configs
// CIRCLES Style
"hyprland/workspaces": {
  "active-only": false,
  "all-outputs": true, 
  "format": "{icon}",
  "show-special": false,
  "on-click": "activate",
  "on-scroll-up": "hyprctl dispatch workspace e+1",
  "on-scroll-down": "hyprctl dispatch workspace e-1",
  "persistent_workspaces": {
    "1": [],
    "2": [],
    "3": [],
    "4": [],
    "5": [],
  },
  "format-icons": {
    "active": "ï†’",
    "default": "ï„Œ",
  },  
},
// ROMAN Numerals style
"hyprland/workspaces#2": {
  "active-only":false,
  "all-outputs": true,
  "format": "{icon}",
  "show-special": false,
  "on-click": "activate",
  "on-scroll-up": "hyprctl dispatch workspace e+1",
  "on-scroll-down": "hyprctl dispatch workspace e-1",
  "persistent_workspaces":{
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
  },
  "format-icons": {
    "1": "I",
    "2": "II",
    "3": "III",
    "4": "IV",
    "5": "V",
    
  },
},
// PACMAN Style
"hyprland/workspaces#3": {
  "active-only":false,
  "all-outputs": true,
  "format": "{icon}",
  "on-click": "activate",
  "on-scroll-up": "hyprctl dispatch workspace e+1",
  "on-scroll-down": "hyprctl dispatch workspace e-1",
  "show-special": false,
  "persistent_workspaces":{
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
  },
  "format": "{icon}",
  "format-icons": {
    "active": " َ°®¯ ",
    "default": " ï…پ ",
    "persistent":"َ°‘ٹ",
  },
},

//  NUMBERS and ICONS style
"hyprland/workspaces#4": {
  "format": "{name}",
  "format": " {name} {icon} ",
  //"format": " {icon} ",
  "show-special": false,
  "on-click": "activate",
  "on-scroll-up": "hyprctl dispatch workspace e+1",
  "on-scroll-down": "hyprctl dispatch workspace e-1",
  "all-outputs": true,
  "sort-by-number": true,
  "format-icons": {
    "1": "ï„  ",
    "2": "ï‰© ",
    "3": "ïپ¼ ",
    "4": "ï€° ",
    "5": "ï†¶ ",
    "6": "ïˆ³ ",
    "7": "ïژ’",
    "8": "ï‹† ",
    "9": "ïپ‹",
    "10": "10",
    "focused": "ï†’",
    "default": "ï„Œ",
	},
},
"backlight": {
  "interval": 2,
  "align": 0,
  "rotate": 0,
  //"format": "{icon} {percent}%",
  //"format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
  "format": "{icon}",
  "format-icons": ["َ°›©", "َ±©ژ", "َ±©ڈ", "َ±©‘", "َ±©’", "َ±©“", "َ±©”", "َ±©•", "َ°›¨"],
  "tooltip-format": "backlight {percent}%",
  "icon-size": 10,
  "on-click": "",
  "on-click-middle": "",
  "on-click-right": "",
  "on-update": "",
  "on-scroll-up": "~/.config/waybar/scripts/Brightness.sh --inc",
  "on-scroll-down": "~/.config/waybar/scripts/Brightness.sh --dec",
  "smooth-scrolling-threshold": 1,
},
    
"battery": {
  "interval": 60,
  "align": 0,
  "rotate": 0,
  //"bat": "BAT1",
  //"adapter": "ACAD",
  "full-at": 100,
  "design-capacity": false,
  "states": {
    "good": 95,
    "warning": 30,
    "critical": 15
           },
  "format": "{capacity}%",
  "format-charging": "ïƒ§  {capacity}%",
  "format-plugged": "َ±ک– ",
  "format-full": "{icon} Full",
  "format-alt": "{icon} {time}",
  "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"],
  "format-time": "{H}h {M}min",
  "tooltip": true,
  "tooltip-format": "{timeTo} {power}w",
  "on-click-middle": "~/.config/waybar/scripts/ChangeBlur.sh",
},
    
"bluetooth": {
  "format": "ïٹ“",
  "format-disabled": "َ°‚³",
  "format-connected": "َ°‚± {num_connections}",
  "tooltip-format": "ïٹ“ {device_alias}",
  "tooltip-format-connected": "{device_enumerate}",
  "tooltip-format-enumerate-connected": "ïٹ“ {device_alias} َ°‚„{device_battery_percentage}%",
  "tooltip": true,
  "on-click": "bluetoothctl",
},
"cava": {
        "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
        "framerate": 30,
        "autosens": 1,
        "sensitivity": 100,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "method": "pipewire",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 4,
        "format-icons" : ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },


"clock": {
	"interval": 1,
  //"format": "ï€— {:%I:%M %p}",
  "format": "ï€— {:%H:%M}",
  "format-alt": "ï€— {:%H:%M  ïپ³ %Y, %d %B, %A}",
  "tooltip-format": "<tt><small>{calendar}</small></tt>",
  "calendar": {
    "mode"          : "year",
    "mode-mon-col"  : 3,
    "weeks-pos"     : "right",
    "on-scroll"     : 1,
    "format": {
    "months":     "<span color='#ffead3'><b>{}</b></span>",
    "days":       "<span color='#ecc6d9'><b>{}</b></span>",
    "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
    "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
    "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
              }
              }
  },              
  "actions":  {
    "on-click-forward": "tz_up",
    "on-click-backward": "tz_down",
    "on-scroll-up": "shift_up",
    "on-scroll-down": "shift_down"
},
 
"cpu": {
  "format": "{usage}% َ°چ›",  
  "interval": 1,
  "format-alt-click": "click",
  "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% َ°چ›",
  "format-icons": ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ"],
  "on-click-right": "gnome-system-monitor",
},
  
"disk": {
  "interval": 30,
  //"format": "َ°‹ٹ",
  "path": "/",
  //"format-alt-click": "click",
  "format": "{percentage_used}% َ°‹ٹ",
  //"tooltip": true,
  "tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)",
},
  
"hyprland/language": {
  "format": "Lang: {}",
  "format-en": "fr",
  "format-tr": "fr",
  "keyboard-name": "at-translated-set-2-keyboard",
  "on-click": "hyprctl switchxkblayout $SET_KB next"
},
  
"hyprland/submap": {
  "format": "<span style=\"italic\">ïŒ‍  {}</span>", // Icon: expand-arrows-alt
  "tooltip": false,
},
  
"hyprland/window": {
  "format": "{}",
  "max-length": 40,
  "separate-outputs": true,
  "offscreen-css" : true,
  "offscreen-css-text": "(inactive)",
   "rewrite": {
        "(.*) â€” Mozilla Firefox": "ï‰© $1",
        "(.*) - fish": "> [$1]",
		"(.*) - zsh": "> [$1]",
		"(.*) - kitty": "> [$1]",
	},
},
"idle_inhibitor": {
  "format": "{icon}",
  "format-icons": {
    "activated": "ïپ® ",
    "deactivated": "ïپ° ",
                  }
},
  
"keyboard-state": {
  //"numlock": true,
  "capslock": true,
  "format": {
    "numlock": "N {icon}",
	"capslock":"َ°ھ› {icon}",
			}, 
  "format-icons": {
    "locked": "ï€£",
    "unlocked": "ï‚œ"
    			  },
},
  
"memory": {
  "interval": 10,
  "format": "{used:0.1f}G َ°¾†",
  "format-alt": "{percentage}% َ°¾†",
  "format-alt-click": "click",
  "tooltip": true,
  "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
  "on-click-right": "kitty --title btop sh -c 'btop'"
},
    
"network": {
  "format": "{ifname}",
  "format-wifi": "{icon}",
  "format-ethernet": "َ°Œک",
  "format-disconnected": "َ°Œ™", 
  "tooltip-format": "{ipaddr} ï„¹ {bandwidthUpBytes} ï„؛ {bandwidthDownBytes}",
  "format-linked": "َ°ˆپ {ifname} (No IP)",
  "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
  "tooltip-format-ethernet": "{ifname} َ°Œک",
  "tooltip-format-disconnected": "َ°Œ™ Disconnected",
  "max-length": 50,
  "format-icons": ["َ°¤¯","َ°¤ں","َ°¤¢","َ°¤¥","َ°¤¨"]
},
    
"pulseaudio": {
  "format": "{icon}",
  "format-bluetooth": "{icon} َ°‚° {volume}%",
  "format-muted": "َ°–پ",
  "format-icons": {
      "headphone": "ï€¥",
      "hands-free": "ï€¥",
      "headset": "ï€¥",
      "phone": "ï‚•",
      "portable": "ï‚•",
      "car": "ï†¹",
  "default": ["ï€¦", "ï€§", "َ°•¾", "ï€¨"], 
  "ignored-sinks": ["Easy Effects Sink"],
  },
  "scroll-step": 5.0,
  "on-click": "~/.config/waybar/scripts/Volume.sh --toggle",
  "on-click-right": "pavucontrol -t 3",
  "on-scroll-up": "~/.config/waybar/scripts/Volume.sh --inc",
  "on-scroll-down": "~/.config/waybar/scripts/Volume.sh --dec",
  "smooth-scrolling-threshold": 1,
},
"custom/firefox": {
  "format": "ï‰© ",
  "on-click": "firefox",
},    
"custom/thunar": {
  "format": "ïپ» ", 
  "on-click": "thunar",
},
"custom/terminal": {
  "format": " ï„  ",
  "on-click": "xfce4-terminal",
},
"pulseaudio#microphone": {
  "format": "{format_source}",
  "format-source": "ï„° {volume}%",
  "format-source-muted": "ï„±",
  "on-click": "~/.config/waybar/scripts/Volume.sh --toggle-mic",
  "on-click-right": "pavucontrol -t 4",
  "on-scroll-up": "~/.config/waybar/scripts/Volume.sh --mic-inc",
  "on-scroll-down": "~/.config/waybar/scripts/Volume.sh --mic-dec",
  "scroll-step": 5,
},
  
"temperature": {
  "interval": 10,
  "tooltip": false,
  "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
  //"thermal-zone": 0,
  "critical-threshold": 82,
  "format-critical": "{temperatureC}آ°C {icon}",
  "format": "{temperatureC}آ°C {icon}",
  "format-icons": ["َ°ˆ¸"],
  "on-click-right": "kitty --title nvtop sh -c 'nvtop'"
},
    
"tray": {
  //"icon-size": 17,
  "spacing": 8,
},
    
"wireplumber": {
  "format": "{icon} {volume} %",
  "format-muted": "ï‘¦ Mute",
  "on-click": "~/.config/waybar/scripts/Volume.sh --toggle",
  "on-click-right": "pavucontrol -t 3",
  "on-scroll-up": "~/.config/waybar/scripts/Volume.sh --inc",
  "on-scroll-down": "~/.config/waybar/scripts/Volume.sh --dec",
  "format-icons": ["ï€¦", "ï€§", "َ°•¾", "ï€¨"], 
},
    
"wlr/taskbar": {
  "format": "{icon} {name} ",
  "icon-size": 16,
  "all-outputs": false,
  "tooltip-format": "{title}",
  "on-click": "activate",
  "on-click-middle": "close",
  "ignore-list": [
        "wofi",
        "rofi",  
                 ]
},
    
"custom/cycle_wall":{
  "format":"ï€¾ ",
  "on-click": "~/.config/waybar/scripts/WallpaperSelect.sh",
  "on-click-right": "~/.config/waybar/scripts/Wallpaper.sh swww",
  "on-click-middle": "~/.config/waybar/scripts/WaybarStyles.sh",
  "tooltip": true,
  "tooltip-format": "Change wallpaper or style"
},
    
"custom/keybinds": {
  "format":"َ°؛پ HINT!",
  "tooltip": false,
  "on-click": "~/.config/waybar/scripts/KeyHints.sh",
},
  
"custom/light_dark": {
  "format": "ï†’",
  "on-click": "~/.config/waybar/scripts/DarkLight.sh",
	"on-click-right": "~/.config/waybar/scripts/WaybarStyles.sh",
  "on-click-middle": "~/.config/waybar/scripts/Wallpaper.sh swww",
  "tooltip": false,
},
    
"custom/lock": {
  "format": "ï€£",
  "on-click": "exec hyprlock",
  "tooltip": false,
},
  
"custom/menu": {
  "format": "ïŒƒ",
  "tooltip": false,
  "on-click": "pkill rofi || rofi -show drun -modi run,drun,filebrowser",
},

"custom/playerctl": {
  "format": "<span>{}</span>",
  "return-type": "json",
  "max-length": 35,
  "exec": "playerctl -a metadata --format '{\"text\": \"{{artist}} ~ {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
  "on-click-middle": "playerctl play-pause",
  "on-click": "playerctl previous",
  "on-click-right": "playerctl next",
  "scroll-step": 5.0,
  "on-scroll-up": "~/.config/waybar/scripts/Volume.sh --inc",
  "on-scroll-down": "~/.config/waybar/scripts/Volume.sh --dec",
  "smooth-scrolling-threshold": 1,
},
    
"custom/power": {
  "format": "âڈ» ",
  "tooltip": false,
  "on-click": "~/.config/waybar/scripts/Wlogout.sh",
  "on-click-right": "~/.config/waybar/scripts/ChangeBlur.sh",
},

// NOTE:! This is only for Arch and Arch Based Distros  
"custom/updater":{
  "format": "ï€™ {}",
  "exec": "checkupdates | wc -l",
  "exec-if": "[[ $(checkupdates | wc -l) ]]",
  "interval": 15,
  "on-click": "kitty -T update paru -Syu || yay -Syu && notify-send 'The system has been updated'",
},
  
"custom/weather": {
  "format": "{}",
  "format-alt": "{alt}: {}",
  "format-alt-click": "click",
  "interval": 3600,
  "return-type": "json",
  "exec": "~/.config/waybar/scripts/Weather.sh",
  //"exec": "~/.config/waybar/scripts/Weather.py",
  "exec-if": "ping wttr.in -c1",
  "tooltip" : true,
},


// Separators
"custom/separator#dot": {
  "format": "ï‘„",
  "interval": "once",
  "tooltip": false
},

"custom/separator#dot-line": {
  "format": "îک،",
  "interval": "once",
  "tooltip": false
},

"custom/separator#line": {
  "format": "|",
  "interval": "once",
  "tooltip": false
},

// Modules below are for vertical layout

"backlight#vertical": {
  "interval": 2,
  "align": 0,
  "rotate": 0,
  "format": "{icon}",
  "format-icons": ["َ°›©", "َ±©ژ", "َ±©ڈ", "َ±©‘", "َ±©’", "َ±©“", "َ±©”", "َ±©•", "َ°›¨"],
  "tooltip-format": "{percent}%",
  "icon-size": 10,
  "on-update": "",
  "icon-size": 10,
  "on-click": "",
  "on-click-middle": "",
  "on-click-right": "",
  "on-update": "",
  "on-scroll-up": "~/.config/waybar/scripts/Brightness.sh --inc",
  "on-scroll-down": "~/.config/waybar/scripts/Brightness.sh --dec",
  "smooth-scrolling-threshold": 1,
},

"clock#vertical": {
   "format": "{:ï€—\n%H\n%M\n%S\n\nïپ³ \n%d\n%m\n%y}",
   "interval": 1,
   //"format": "{:ï€—\n%I\n%M\n%p\n\nïپ³ \n%d\n%m\n%y}",
   "tooltip": true,
   "tooltip-format": "{calendar}",
   "calendar": {
     "mode": "year",
