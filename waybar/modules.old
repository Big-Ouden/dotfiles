     "today": "<span color='#0dbc79'>{}</span>",
     }
   }
},
"cpu#vertical": {
  "format": "َ°چ›\n{usage}%",  
  "interval": 1,
  "on-click-right": "gnome-system-monitor",
},

"memory#vertical": {
  "interval": 10,
  "format": "َ°¾†\n{percentage}%",
  "format-alt": "َ°¾†\n{used:0.1f}G",
